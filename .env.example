# ════════════════════════════════════════════════════════════
# CLAUDE-BRAIN — .env.example
# 100% Docker — no se instala nada en el host
#
# SETUP:
#   1. cp .env.example .env
#   2. Rellenar valores (especialmente CLAUDE_CREDENTIALS_JSON)
#   3. docker compose up -d --build
# ════════════════════════════════════════════════════════════

# ── CLAUDE CODE MAX AUTH ──────────────────────────────────────
#
# OPCIÓN A (recomendada): exportar credenciales de tu máquina local
# En tu máquina donde ya tienes Claude Code autenticado:
#   cat ~/.claude/.credentials.json
# Pega el JSON completo aquí (una sola línea):
CLAUDE_CREDENTIALS_JSON=

# OPCIÓN B: dejar vacío y autenticar después de arrancar:
#   docker compose exec agent-api claude auth login

# CRITICO: NO añadir ANTHROPIC_API_KEY
# Si está presente cobra por token (separado del Max plan)
# Sin esta variable el CLI usa OAuth y es $0 extra

# ── DOMINIO (opcional, para SSL con nginx) ────────────────────
DOMAIN=localhost
EMAIL=admin@localhost
SITE_URL=http://localhost:3080

# ── LIBRECHAT UI ──────────────────────────────────────────────
ANTHROPIC_API_KEY_LIBRECHAT=sk-ant-...

# ── GITHUB ───────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── SUPABASE (self-hosted) ────────────────────────────────────
POSTGRES_PASSWORD=CAMBIAR_openssl_rand_hex_32
JWT_SECRET=CAMBIAR_openssl_rand_hex_64
SUPABASE_SERVICE_KEY=eyJ_CAMBIAR

# ── REDIS ────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_openssl_rand_hex_16

# ── N8N ──────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_openssl_rand_base64_24
N8N_API_KEY=CAMBIAR_openssl_rand_hex_32

# ── AGENT CONFIG ──────────────────────────────────────────────
AGENT_MAX_TURNS=25
AGENT_TIMEOUT_SECONDS=300
AGENT_MAX_SUBAGENTS=4
