# ════════════════════════════════════════════════
# CLAUDE-BRAIN — Environment Variables Template
# Copia este archivo a .env y rellena tus valores
# ════════════════════════════════════════════════

# ── DOMINIO ──────────────────────────────────────
DOMAIN=agent.tudominio.com
EMAIL=tu@email.com

# ── CLAUDE CODE ──────────────────────────────────
# CRÍTICO: NO poner ANTHROPIC_API_KEY en el agente
# El agente usa Max OAuth (claude auth login en el VPS)
# Solo poner aquí si LibreChat necesita API para su UI:
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── GITHUB ───────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=tu_usuario

# ── SUPABASE (self-hosted) ────────────────────────
POSTGRES_PASSWORD=CAMBIAR_openssl_rand_hex_32
JWT_SECRET=CAMBIAR_openssl_rand_hex_64
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Genera las keys en: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys

# ── REDIS ────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_openssl_rand_hex_16

# ── N8N ──────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_openssl_rand_base64_24
N8N_API_KEY=CAMBIAR_openssl_rand_hex_32

# ── EMBEDDINGS (local, no necesita API key) ───────
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_URL=http://embeddings:8080

# ── AGENT CONFIG ──────────────────────────────────
AGENT_MAX_TURNS=25
AGENT_TIMEOUT_SECONDS=300
AGENT_MAX_SUBAGENTS=4
AGENT_WORKDIR=/workspaces

# ── LIBRECHAT (Web UI) ────────────────────────────
MONGO_URI=mongodb://mongodb:27017/librechat
